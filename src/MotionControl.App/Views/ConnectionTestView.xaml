<UserControl x:Class="MotionControl.App.Views.ConnectionTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#2D2D30">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：连接控制 -->
        <Border Grid.Column="0" Background="#3C3C3C" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="控制器连接" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                <!-- IP地址 -->
                <TextBlock Text="IP地址" Foreground="#888888" Margin="0,0,0,5"/>
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                        FontSize="16" Padding="10" Margin="0,0,0,10"/>

                <!-- 端口 -->
                <TextBlock Text="端口" Foreground="#888888" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                        FontSize="16" Padding="10" Margin="0,0,0,15"/>

                <!-- 连接状态 -->
                <Border Background="#1E1E1E" CornerRadius="4" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="连接状态" Foreground="#888888" FontSize="12"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 连接/断开按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="连接" Command="{Binding ConnectCommand}"
                            Background="#107C10" Foreground="White"
                            FontSize="14" Padding="25,12" Margin="5,0"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="断开" Command="{Binding DisconnectCommand}"
                            Background="#E81123" Foreground="White"
                            FontSize="14" Padding="25,12" Margin="5,0"
                            IsEnabled="{Binding IsConnected}"/>
                </StackPanel>

                <Separator Background="#5C5C5C" Margin="0,20"/>

                <!-- 控制器信息 -->
                <TextBlock Text="控制器信息" FontSize="14" Foreground="White" Margin="0,0,0,10"/>
                <Border Background="#1E1E1E" CornerRadius="4" Padding="10">
                    <TextBlock Text="{Binding ControllerInfo}" Foreground="#888888" TextWrapping="Wrap"/>
                </Border>

                <Separator Background="#5C5C5C" Margin="0,20"/>

                <!-- 测试按钮 -->
                <TextBlock Text="连接测试" FontSize="14" Foreground="White" Margin="0,0,0,10"/>

                <Button Content="测试连接" Command="{Binding TestConnectionCommand}"
                        Background="#0078D4" Foreground="White" Padding="15,10" Margin="0,5" HorizontalAlignment="Stretch"/>
                <Button Content="读取轴数据" Command="{Binding TestReadAxisCommand}"
                        Background="#00B7C3" Foreground="White" Padding="15,10" Margin="0,5" HorizontalAlignment="Stretch"/>
                <Button Content="测试轴使能" Command="{Binding TestEnableAxisCommand}"
                        Background="#FF8C00" Foreground="White" Padding="15,10" Margin="0,5" HorizontalAlignment="Stretch"/>
                <Button Content="测试运动" Command="{Binding TestMoveCommand}"
                        Background="#8764B8" Foreground="White" Padding="15,10" Margin="0,5" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- 右侧：测试结果 -->
        <Border Grid.Column="1" Background="#3C3C3C" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="测试日志" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <ProgressBar IsIndeterminate="True" Width="100" Height="16" Margin="15,0,0,0"
                                 Visibility="{Binding TestInProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding TestResults}"
                                  Foreground="#888888" FontFamily="Consolas" FontSize="12"
                                  Padding="10" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
