<UserControl x:Class="MotionControl.App.Views.AxisDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#2D2D30">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：轴选择 -->
        <Border Grid.Column="0" Background="#3C3C3C" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="轴选择" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                <TextBlock Text="选择轴号" Foreground="#888888" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding AxisNumbers}"
                         SelectedItem="{Binding SelectedAxisNumber}"
                         FontSize="18" Padding="10" Margin="0,0,0,15"/>

                <TextBlock Text="当前状态" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,10,0,15"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="位置:" Foreground="#888888"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentPosition, StringFormat=F3}" Foreground="White" FontWeight="Bold"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="使能:" Foreground="#888888" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding IsEnabled}" Foreground="{Binding IsEnabled, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#107C10|#E81123'}" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="回零:" Foreground="#888888" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IsHomed}" Foreground="{Binding IsHomed, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#107C10|#888888'}" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="运动:" Foreground="#888888" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding IsMoving}" Foreground="#FF8C00" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="报警:" Foreground="#888888" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HasAlarm}" Foreground="{Binding HasAlarm, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#E81123|#107C10'}" Margin="0,5,0,0"/>
                </Grid>

                <Separator Background="#5C5C5C" Margin="0,10"/>

                <!-- 使能/失能按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Content="使能" Command="{Binding EnableCommand}"
                            Background="#107C10" Foreground="White" Padding="20,10" Margin="5,0"/>
                    <Button Content="失能" Command="{Binding DisableCommand}"
                            Background="#E81123" Foreground="White" Padding="20,10" Margin="5,0"/>
                </StackPanel>

                <!-- 回零按钮 -->
                <Button Content="回零" Command="{Binding HomeCommand}"
                        Background="#FF8C00" Foreground="White" FontSize="14" Padding="15,10"
                        Margin="0,10,0,0" HorizontalAlignment="Stretch"/>

                <!-- 清除报警 -->
                <Button Content="清除报警" Command="{Binding ClearAlarmCommand}"
                        Background="#8764B8" Foreground="White" Padding="15,10"
                        Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- 右侧：控制面板 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 参数设置 -->
            <Border Grid.Row="0" Background="#3C3C3C" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="JOG速度 (mm/min)" Foreground="#888888" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding JogVelocity, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="16" Padding="10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="运动速度 (mm/min)" Foreground="#888888" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MoveVelocity, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="16" Padding="10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="加速度 (mm/s²)" Foreground="#888888" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Acceleration, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="16" Padding="10"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- JOG和定位控制 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- JOG控制 -->
                <Border Grid.Column="0" Background="#3C3C3C" CornerRadius="8" Padding="15" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="JOG 控制" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 正向JOG -->
                            <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                    Content="+ JOG"
                                    Command="{Binding JogPlusCommand}"
                                    Background="#0078D4" Foreground="White"
                                    FontSize="18" FontWeight="Bold"
                                    Margin="50,10" Padding="20"/>

                            <!-- 停止按钮 -->
                            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Content="STOP"
                                    Command="{Binding StopJogCommand}"
                                    Background="#E81123" Foreground="White"
                                    FontSize="16" FontWeight="Bold"
                                    Margin="50,10" Padding="20"/>

                            <!-- 负向JOG -->
                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Content="- JOG"
                                    Command="{Binding JogMinusCommand}"
                                    Background="#0078D4" Foreground="White"
                                    FontSize="18" FontWeight="Bold"
                                    Margin="50,10" Padding="20"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 定位控制 -->
                <Border Grid.Column="1" Background="#3C3C3C" CornerRadius="8" Padding="15" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="定位控制" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                        <TextBlock Text="目标位置" Foreground="#888888" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="18" Padding="10" Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="绝对运动" Command="{Binding MoveAbsCommand}"
                                    Background="#0078D4" Foreground="White"
                                    FontSize="14" Padding="20,10" Margin="5"/>
                            <Button Content="相对+10" Command="{Binding MoveRelPlusCommand}"
                                    Background="#00B7C3" Foreground="White"
                                    FontSize="14" Padding="15,10" Margin="5"/>
                            <Button Content="相对-10" Command="{Binding MoveRelMinusCommand}"
                                    Background="#00B7C3" Foreground="White"
                                    FontSize="14" Padding="15,10" Margin="5"/>
                        </StackPanel>

                        <Separator Background="#5C5C5C" Margin="0,20"/>

                        <Button Content="立即停止" Command="{Binding StopCommand}"
                                Background="#E81123" Foreground="White"
                                FontSize="14" Padding="20,10" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 状态消息 -->
            <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#888888" FontSize="14"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
