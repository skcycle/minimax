{
  "Logging": {
    "LogLevel": "Debug",
    "ConsoleEnabled": true,
    "FileEnabled": false,
    "FilePath": "logs/motioncontrol.log"
  },
  "Controller": {
    "IpAddress": "192.168.0.100",
    "Port": 5005,
    "ConnectionTimeoutMs": 5000,
    "ReconnectIntervalMs": 3000,
    "MaxReconnectAttempts": 5
  },
  "Polling": {
    "IntervalMs": 100,
    "BatchRead": true
  },
  "Axes": [
    { "Number": 0, "Name": "X", "GroupId": "Gantry1", "MaxVelocity": 5000, "MaxAcceleration": 20000 },
    { "Number": 1, "Name": "Y", "GroupId": "Gantry1", "MaxVelocity": 5000, "MaxAcceleration": 20000 },
    { "Number": 2, "Name": "Z", "GroupId": null, "MaxVelocity": 3000, "MaxAcceleration": 15000 },
    { "Number": 3, "Name": "A", "GroupId": null, "MaxVelocity": 2000, "MaxAcceleration": 10000 },
    { "Number": 4, "Name": "B", "GroupId": null, "MaxVelocity": 2000, "MaxAcceleration": 10000 },
    { "Number": 5, "Name": "C", "GroupId": null, "MaxVelocity": 2000, "MaxAcceleration": 10000 }
  ],
  "Safety": {
    "EnableEStopCheck": true,
    "EnableSoftLimits": true,
    "EnableFollowErrorCheck": true,
    "FollowErrorThreshold": 1.0
  }
}
